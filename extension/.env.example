INDEXER_URL=
INDEXER_V2_URL=

# For local development, analytics events are logged to console but not uploaded (no key needed).
# To test Amplitude locally, add the line below with your Amplitude key, then run: yarn start
#
# AMPLITUDE_KEY=
#
# Production/Beta builds pass AMPLITUDE_KEY and SENTRY_KEY via CLI --env flag:
#   yarn build:production --env AMPLITUDE_KEY="your-key" SENTRY_KEY="your-key"
# In CI, these come from GitHub secrets (see .github/workflows/)
