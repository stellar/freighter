INDEXER_URL=
INDEXER_V2_URL=

# For local development, analytics events are logged to console but not uploaded (no key needed).
# To test Amplitude locally, add the lines below with your keys, then run: yarn start
#
# AMPLITUDE_KEY=
# AMPLITUDE_EXPERIMENT_DEPLOYMENT_KEY=
#
# AMPLITUDE_KEY — required for analytics events (Amplitude Analytics SDK).
# AMPLITUDE_EXPERIMENT_DEPLOYMENT_KEY — required for remote feature flags (Amplitude Experiment SDK).
#
# Production/Beta builds pass these keys plus SENTRY_KEY via CLI --env flag:
#   yarn build:production --env AMPLITUDE_KEY="your-key" AMPLITUDE_EXPERIMENT_DEPLOYMENT_KEY="your-key" SENTRY_KEY="your-key"
# In CI, these come from GitHub secrets (see .github/workflows/)
